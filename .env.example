# Browser -> same-origin proxy. Keep this as /api on Netlify to avoid CORS.
VITE_API_BASE_URL=/api

# Vite dev server proxy target for local npm run dev.
VITE_DEV_API_PROXY_TARGET=http://api.com

# Netlify Function proxy target. Set this in Netlify environment variables too.
CERTI_API_BASE_URL=http://api.com
